<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             xmlns:vm="using:D8_Demo.ViewModels"
             x:DataType="vm:CardCheckViewModel"
             x:Class="D8_Demo.Views.UserControl.CardCheckView">
    <Design.DataContext>
        <vm:CardCheckViewModel />
    </Design.DataContext>

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto" RowSpacing="20">
        <Border BorderThickness="1" BorderBrush="Lavender" CornerRadius="10" Padding="20">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Spacing="10">
                <TextBlock Text="检测结果" FontSize="18" FontWeight="SemiBold"></TextBlock>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1"  Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <PathIcon Data="M 12,2A 10,10 0 1 1 11.999,2Z"
                          Width="24" Height="24"
                          Foreground="{Binding FindCard}" />
                <Button Width="100" Height="40" Theme="{DynamicResource SolidButton}"
                        Command="{Binding CheckChipTypeCommand}">
                    开始检测
                </Button>
                <Button Width="100" Height="40" Classes="Warning" Command="{Binding StopChipTypeCommand}">停止检测</Button>
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" ColumnSpacing="20">
                <ProgressBar Height="5" Background="Lavender"></ProgressBar>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                    <TextBlock Text="{Binding Count, StringFormat='已检测 {0} 轮'}"></TextBlock>
                    <TextBlock Text="{Binding LastDuration, StringFormat='上次耗时 {0} ms'}" ></TextBlock>
                </StackPanel>
               
            </Grid>
        </Grid>
        </Border>
        
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
            <Border BorderThickness="1" BorderBrush="Lavender" CornerRadius="10" Padding="20">
            </Border>
            <Border Grid.Column="1"  BorderThickness="1" BorderBrush="Lavender" CornerRadius="10" Padding="20">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" >
                    <StackPanel Grid.Row="0" HorizontalAlignment="Left" Spacing="10">
                        <TextBlock Text="卡片检测" FontSize="18" FontWeight="SemiBold"></TextBlock>
                        <Label HorizontalContentAlignment="Center" Classes="Ghost Large Green"
                               FontWeight="Bold" 
                               MinWidth="200" MinHeight="40" Theme="{DynamicResource TagLabel}"
                               Content="{Binding CardType}">
                        </Label>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="卡返回值：" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                        <TextBox MinWidth="400" Text="{Binding ReturnValue}" IsReadOnly="True"></TextBox>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="复位信息：" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                        <TextBox MinWidth="400" Text="{Binding ATS}" IsReadOnly="True"></TextBox>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="10" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="特征值1：" VerticalAlignment="Center"></TextBlock>
                        <TextBox Text="{Binding Feature1}" IsReadOnly="True" MinWidth="100"></TextBox>
                        <TextBlock Text="特征值2：" VerticalAlignment="Center"></TextBlock>
                        <TextBox Text="{Binding Feature2}" IsReadOnly="True" MinWidth="100"></TextBox>
                    </StackPanel>


                </Grid>
            </Border>
        </Grid>

    </Grid>

</UserControl>