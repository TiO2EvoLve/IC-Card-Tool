<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             xmlns:vm="using:D8_Demo.ViewModels"
             x:DataType="vm:M1ReadViewModel"
             x:Class="D8_Demo.Views.UserControl.M1ReadView">
    <Design.DataContext>
        <vm:M1ReadViewModel />
    </Design.DataContext>


    <Grid Margin="10" RowDefinitions="Auto,*" RowSpacing="10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <TextBlock Text="扇区密码:" VerticalAlignment="Center" />
            <TextBox Width="200" Text="{Binding PassWorld}" />
            <Button Command="{Binding ReadCommand}" Theme="{DynamicResource SolidButton}" Classes="Success">读取</Button>
            <Button Classes="Secondary">写入</Button>
        </StackPanel>
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Sectors}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <!-- 用 UniformGrid 来自动布局 -->
                    <UniformGrid Margin="5" Rows="16" Columns="1" ColumnSpacing="10" RowSpacing="10" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                        <Label Classes="Ghost Blue"
                               Theme="{DynamicResource TagLabel}"
                               HorizontalAlignment="Center"
                               Content="{Binding Title}" />
                        <UniformGrid Columns="4" Grid.Column="1" 
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Margin="0">
    
                            <Viewbox>
                                <Border MinWidth="80" Background="Transparent" >
                                    <TextBox Text="{Binding Block0}" 
                                             BorderThickness="0"
                                             Background="Transparent"/>
                                </Border>
                            </Viewbox>
    
                            <Viewbox>
                                <Border MinWidth="80" Background="Transparent">
                                    <TextBox Text="{Binding Block1}" 
                                             BorderThickness="0"
                                             Background="Transparent"/>
                                </Border>
                            </Viewbox>
    
                            <Viewbox>
                                <Border MinWidth="80" Background="Transparent">
                                    <TextBox Text="{Binding Block2}" 
                                             BorderThickness="0"
                                             Background="Transparent"/>
                                </Border>
                            </Viewbox>
    
                            <Viewbox>
                                <Border MinWidth="80" Background="Transparent">
                                    <TextBox Text="{Binding Block3}" 
                                             BorderThickness="0"
                                             Background="Transparent"/>
                                </Border>
                            </Viewbox>
    
                        </UniformGrid>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>


</UserControl>