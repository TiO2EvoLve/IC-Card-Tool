<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             xmlns:vm="using:D8_Demo.ViewModels"
             x:DataType="vm:M1ReadViewModel"
             x:Class="D8_Demo.Views.UserControl.M1ReadView">
    <Design.DataContext>
        <vm:M1ReadViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.block-cell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.block-cell.selected">
            <Setter Property="Background" Value="#f6ffed" />
            <Setter Property="BorderBrush" Value="#b7eb8f" />
            <Setter Property="Foreground" Value="#52c41a" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="10" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <TextBlock Text="扇区密码:" VerticalAlignment="Center" />
            <TextBox Width="200" Text="{Binding PassWorld}" />
            <Button Command="{Binding ReadCommand}" Theme="{DynamicResource SolidButton}" Classes="Success">读取</Button>
            <Button Classes="Secondary">写入</Button>
        </StackPanel>


        <ItemsControl Grid.Row="1" ItemsSource="{Binding Sectors}" Margin="5">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="8" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SectorViewModel">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Classes="Ghost Blue"
                               Theme="{DynamicResource TagLabel}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Content="{Binding Title}" />
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Blocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:BlockCellViewModel">
                                    <Button Classes="block-cell"
                                            Classes.selected="{Binding IsSelected}"
                                            Command="{Binding SelectCommand}">
                                        <TextBlock Text="{Binding Data}"
                                                   TextAlignment="Left"
                                                   FontSize="10" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <TextBlock Text="块数据：" VerticalAlignment="Center" />
            <TextBox MinWidth="300" Text="{Binding SelectedBlockData}" />
            <TextBlock Text="位置：" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SelectedPosition}" VerticalAlignment="Center" Foreground="Blue" />
            <Button Content="写入" Command="{Binding WriteCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>